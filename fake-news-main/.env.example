# Django Settings
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=your-secret-key-here-change-this
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost

# Database (Auto-configured by Railway/Render, optional locally)
DATABASE_URL=postgresql://user:password@localhost:5432/checkdem

# Redis (For Celery tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Admin User (Created on first deployment)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@checkdem.com
ADMIN_PASSWORD=change-this-secure-password

# Optional: Mistral AI (for enhanced validation)
CHECKDEM_MISTRAL_API_KEY=your-mistral-key
CHECKDEM_MISTRAL_API_BASE_URL=https://api.mistral.ai/v1
CHECKDEM_MISTRAL_MODEL=mistral-small-latest

# Optional: Whisper Transcription
CHECKDEM_WHISPER_MODEL=small
CHECKDEM_WHISPER_DEVICE=cpu
CHECKDEM_WHISPER_COMPUTE_TYPE=int8
CHECKDEM_FFMPEG_PATH=ffmpeg

# Frontend
VITE_API_URL=https://api.yourdomain.com
