# ─────────────────────────────────────────────────────────────────
# CheckDem Backend — Environment Variables Template
# Copy this to .env and fill in your real values.
# NEVER commit the filled .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Django core ──────────────────────────────────────────────────
# Generate a new key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-this-with-a-real-secret-key

DJANGO_DEBUG=False

# Comma-separated — add your Render domain here
DJANGO_ALLOWED_HOSTS=fake-news-prri.onrender.com

# FIX #6: CORS origins now read from env, not hardcoded.
# Add every Vercel URL your frontend uses (preview URLs too).
DJANGO_CORS_ALLOWED_ORIGINS=https://fake-news-self.vercel.app,https://fake-news-nu.vercel.app

# ── Database ─────────────────────────────────────────────────────
# Leave blank to use SQLite (default).
# For Postgres: DATABASE_URL=postgres://user:pass@host:5432/dbname
DATABASE_URL=

# ── Admin bootstrap (FIX #2) ─────────────────────────────────────
# Set these on Render. On first `migrate` the superuser is auto-created.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@checkdem.io
ADMIN_PASSWORD=change-me-before-deploy

# ── Celery / Redis ───────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Set to True only in development/test to run tasks synchronously
CELERY_TASK_ALWAYS_EAGER=False

# ── AI / ML ──────────────────────────────────────────────────────
# Leave blank to use the heuristic validator only.
CHECKDEM_MISTRAL_API_KEY=
CHECKDEM_MISTRAL_MODEL=mistral-small-latest
CHECKDEM_MISTRAL_TIMEOUT_SECONDS=30

# Whisper (media transcription)
CHECKDEM_WHISPER_MODEL=small
CHECKDEM_WHISPER_DEVICE=cpu
CHECKDEM_WHISPER_COMPUTE_TYPE=int8
CHECKDEM_FFMPEG_PATH=
