# Django Settings
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=django-insecure-dev-key-for-testing-only-change-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,*.local

# Database
DJANGO_SQLITE_PATH=db.sqlite3

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Celery/Redis (optional for basic testing)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Media Files
MEDIA_URL=/media/
MEDIA_ROOT=media/

# FFmpeg Configuration (if testing audio/video processing)
CHECKDEM_FFMPEG_PATH=ffmpeg
